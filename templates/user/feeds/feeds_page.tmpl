{{template "base/head" .}}
<div role="main" aria-label="{{.Title}}" class="page-content feeds-page">
	<div class="ui container">
		<a href="{{AppSubUrl}}/" class="back-button tw-inline-flex tw-items-center tw-gap-1 tw-text-14 tw-mt-4 tw-text-primary">
			{{svg "octicon-chevron-left" 14}} {{ctx.Locale.Tr "home.back"}}
		</a>

		<div class="feeds-page-toolbar tw-mt-4 tw-flex tw-items-center tw-gap-3">
			<form action="{{AppSubUrl}}/feeds" method="get" class="feeds-page-search tw-flex-1" id="feeds-search-form">
				{{range .Filters}}<input type="hidden" name="filter" value="{{.}}">{{end}}
				{{if .Period}}<input type="hidden" name="period" value="{{.Period}}">{{end}}
				<span class="feeds-search-icon">{{svg "octicon-search" 16}}</span>
				<input type="text" name="q" value="{{.Keyword}}" class="feeds-search-input" placeholder="{{ctx.Locale.Tr "home.search_placeholder"}}">
			</form>

			<!-- Filter dropdown with checkboxes -->
			<div class="feeds-filter-wrapper">
				<button type="button" class="feeds-filter-btn" id="feeds-filter-toggle" aria-expanded="false">
					{{svg "octicon-filter" 14}} {{ctx.Locale.Tr "filter"}}
					{{svg "octicon-chevron-down" 12 "feeds-filter-chevron"}}
				</button>
				<div id="feeds-filter-panel" class="feeds-filter-panel tw-hidden" role="dialog" aria-label="{{ctx.Locale.Tr "home.filter_options"}}">
					<a href="{{AppSubUrl}}/feeds?{{if .Period}}period={{.Period}}&{{end}}{{if .Keyword}}q={{.Keyword | QueryEscape}}&{{end}}" class="feeds-filter-clear">{{ctx.Locale.Tr "home.clear_filter"}}</a>
					<div class="feeds-filter-divider"></div>
					<div class="feeds-filter-section">{{ctx.Locale.Tr "home.filter_subject"}}</div>
					<label class="feeds-filter-item">
						<input type="checkbox" class="feeds-filter-checkbox" value="articles" {{if index .FiltersMap "articles"}}checked{{end}}>
						{{ctx.Locale.Tr "home.filter_articles"}}
					</label>
					<label class="feeds-filter-item">
						<input type="checkbox" class="feeds-filter-checkbox" value="change_requests" {{if index .FiltersMap "change_requests"}}checked{{end}}>
						{{ctx.Locale.Tr "home.filter_change_requests"}}
					</label>
					<label class="feeds-filter-item">
						<input type="checkbox" class="feeds-filter-checkbox" value="users" {{if index .FiltersMap "users"}}checked{{end}}>
						{{ctx.Locale.Tr "home.filter_users"}}
					</label>
					<label class="feeds-filter-item">
						<input type="checkbox" class="feeds-filter-checkbox" value="mentions" {{if index .FiltersMap "mentions"}}checked{{end}}>
						{{ctx.Locale.Tr "home.filter_mentions"}}
					</label>
				</div>
			</div>

			<!-- Sort/period dropdown -->
			<div class="ui dropdown feeds-sort-btn">
				<span><span class="feeds-sort-icon">{{svg "octicon-arrow-switch" 14}}</span> {{ctx.Locale.Tr "home.sort"}}</span>
				{{svg "octicon-chevron-down" 12 "dropdown icon"}}
				<div class="menu">
					<a class="item {{if not .Period}}active{{end}}" href="{{AppSubUrl}}/feeds?{{range .Filters}}filter={{.}}&{{end}}{{if .Keyword}}q={{.Keyword | QueryEscape}}&{{end}}">{{ctx.Locale.Tr "all"}}</a>
					<a class="item {{if eq .Period "today"}}active{{end}}" href="{{AppSubUrl}}/feeds?period=today&{{range .Filters}}filter={{.}}&{{end}}{{if .Keyword}}q={{.Keyword | QueryEscape}}&{{end}}">{{ctx.Locale.Tr "home.period_today"}}</a>
					<a class="item {{if eq .Period "week"}}active{{end}}" href="{{AppSubUrl}}/feeds?period=week&{{range .Filters}}filter={{.}}&{{end}}{{if .Keyword}}q={{.Keyword | QueryEscape}}&{{end}}">{{ctx.Locale.Tr "home.period_week"}}</a>
					<a class="item {{if eq .Period "last_week"}}active{{end}}" href="{{AppSubUrl}}/feeds?period=last_week&{{range .Filters}}filter={{.}}&{{end}}{{if .Keyword}}q={{.Keyword | QueryEscape}}&{{end}}">{{ctx.Locale.Tr "home.period_last_week"}}</a>
					<a class="item {{if eq .Period "3_months"}}active{{end}}" href="{{AppSubUrl}}/feeds?period=3_months&{{range .Filters}}filter={{.}}&{{end}}{{if .Keyword}}q={{.Keyword | QueryEscape}}&{{end}}">{{ctx.Locale.Tr "home.period_3_months"}}</a>
					<a class="item {{if eq .Period "6_months"}}active{{end}}" href="{{AppSubUrl}}/feeds?period=6_months&{{range .Filters}}filter={{.}}&{{end}}{{if .Keyword}}q={{.Keyword | QueryEscape}}&{{end}}">{{ctx.Locale.Tr "home.period_6_months"}}</a>
				</div>
			</div>
		</div>

		<h2 class="feeds-page-heading tw-mt-7 tw-mb-4">{{ctx.Locale.Tr "home.your_feeds"}}</h2>

		<div class="feeds-card-list">
			{{range .Feeds}}
			<div class="feeds-card">
				<a href="{{.GetCardLink ctx}}" class="feeds-card-link" aria-hidden="true" tabindex="-1"></a>
				<div class="feeds-card-header">
					<div class="feeds-card-actor">
						{{ctx.AvatarUtils.AvatarByAction .}}
						<div class="feeds-card-actor-info">
							<span>
								{{if gt .ActUser.ID 0}}
									<a href="{{AppSubUrl}}/{{(.GetActUserName ctx) | PathEscape}}" title="{{.GetActDisplayNameTitle ctx}}" class="tw-font-semibold">{{.GetActDisplayName ctx}}</a>
								{{else}}
									<span class="tw-font-semibold">{{.ShortActUserName ctx}}</span>
								{{end}}
								{{template "shared/feed_action_text" .}}
							</span>
							<span class="feeds-card-time">{{DateUtils.TimeSince .GetCreate}}</span>
						</div>
					</div>
				</div>
				{{if and (.GetOpType.InActions "commit_repo" "mirror_sync_push") (not (IsArticleOwnerUpdate ctx .))}}
					{{$push := ActionContent2Commits .}}
					{{$repoLink := (.GetRepoLink ctx)}}
					{{$repo := .Repo}}
					<div class="feeds-card-body tw-flex tw-flex-col tw-gap-1">
						{{range $push.Commits}}
							{{$commitLink := printf "%s/commit/%s" $repoLink .Sha1}}
							<div class="flex-text-block">
								<img loading="lazy" alt class="ui avatar" src="{{$push.AvatarLink ctx .AuthorEmail}}" title="{{.AuthorName}}" width="16" height="16">
								<a class="ui sha label" href="{{$commitLink}}">{{ShortSha .Sha1}}</a>
								<span class="text truncate">{{ctx.RenderUtils.RenderCommitMessage .Message $repo}}</span>
							</div>
						{{end}}
						{{if and (gt $push.Len 1) $push.CompareURL}}
							<a href="{{AppSubUrl}}/{{$push.CompareURL}}">{{ctx.Locale.Tr "action.compare_commits" $push.Len}} »</a>
						{{end}}
					</div>
				{{else if .GetOpType.InActions "create_issue"}}
					<div class="feeds-card-body">
						<div class="feeds-card-title">{{index .GetIssueInfos 1 | ctx.RenderUtils.RenderIssueSimpleTitle}}</div>
					</div>
				{{else if .GetOpType.InActions "create_pull_request"}}
					<div class="feeds-card-body">
						<div class="feeds-card-title">{{index .GetIssueInfos 1 | ctx.RenderUtils.RenderIssueSimpleTitle}}</div>
					</div>
				{{else if .GetOpType.InActions "merge_pull_request" "auto_merge_pull_request"}}
					<div class="feeds-card-body">
						<div class="feeds-card-title">{{(.GetIssueTitle ctx) | ctx.RenderUtils.RenderIssueSimpleTitle}}</div>
						<div class="feeds-card-badges">
							<span class="feeds-badge feeds-badge-merged">{{svg "octicon-git-merge" 14}} {{ctx.Locale.Tr "repo.pulls.merged"}}</span>
						</div>
					</div>
				{{else if .GetOpType.InActions "close_pull_request"}}
					<div class="feeds-card-body">
						<div class="feeds-card-title">{{(.GetIssueTitle ctx) | ctx.RenderUtils.RenderIssueSimpleTitle}}</div>
						<div class="feeds-card-badges">
							<span class="feeds-badge feeds-badge-closed">{{svg "octicon-git-pull-request-closed" 14}} {{ctx.Locale.Tr "repo.issues.closed_title"}}</span>
						</div>
					</div>
				{{else if .GetOpType.InActions "reopen_pull_request"}}
					<div class="feeds-card-body">
						<div class="feeds-card-title">{{(.GetIssueTitle ctx) | ctx.RenderUtils.RenderIssueSimpleTitle}}</div>
						<div class="feeds-card-badges">
							<span class="feeds-badge feeds-badge-open">{{svg "octicon-git-pull-request" 14}} {{ctx.Locale.Tr "repo.issues.open_title"}}</span>
						</div>
					</div>
				{{else if .GetOpType.InActions "close_issue"}}
					<div class="feeds-card-body">
						<div class="feeds-card-title">{{(.GetIssueTitle ctx) | ctx.RenderUtils.RenderIssueSimpleTitle}}</div>
						<div class="feeds-card-badges">
							<span class="feeds-badge feeds-badge-closed">{{svg "octicon-issue-closed" 14}} {{ctx.Locale.Tr "repo.issues.closed_title"}}</span>
						</div>
					</div>
				{{else if .GetOpType.InActions "reopen_issue"}}
					<div class="feeds-card-body">
						<div class="feeds-card-title">{{(.GetIssueTitle ctx) | ctx.RenderUtils.RenderIssueSimpleTitle}}</div>
						<div class="feeds-card-badges">
							<span class="feeds-badge feeds-badge-open">{{svg "octicon-issue-reopened" 14}} {{ctx.Locale.Tr "repo.issues.open_title"}}</span>
						</div>
					</div>
				{{else if .GetOpType.InActions "comment_issue" "approve_pull_request" "reject_pull_request" "comment_pull"}}
					<div class="feeds-card-body">
						<div class="feeds-card-title">{{(.GetIssueTitle ctx) | ctx.RenderUtils.RenderIssueSimpleTitle}}</div>
						{{$comment := index .GetIssueInfos 1}}
						{{if $comment}}
							<div class="render-content markup tw-text-14 tw-mt-2">{{ctx.RenderUtils.MarkdownToHtml $comment}}</div>
						{{end}}
					</div>
				{{else if .GetOpType.InActions "pull_review_dismissed"}}
					<div class="feeds-card-body">
						<div class="feeds-card-title">{{(.GetIssueTitle ctx) | ctx.RenderUtils.RenderIssueSimpleTitle}}</div>
						<div class="feeds-card-meta-text">{{ctx.Locale.Tr "action.review_dismissed_reason"}}: {{index .GetIssueInfos 2 | ctx.RenderUtils.RenderEmoji}}</div>
					</div>
				{{end}}
			</div>
			{{else}}
			<div class="feeds-page-empty">
				<p>{{ctx.Locale.Tr "no_results_found"}}</p>
			</div>
			{{end}}
		</div>

		{{with .Page.Paginater}}
		{{$params := $.Page.GetParams}}
		{{if or (eq .TotalPages -1) (gt .TotalPages 1)}}
		<nav class="feeds-pagination tw-mt-8" aria-label="Pagination">
			<a class="feeds-pg-item feeds-pg-nav{{if not .HasPrevious}} feeds-pg-disabled{{end}}"
				{{if .HasPrevious}}href="{{AppSubUrl}}/feeds?page={{.Previous}}{{if $params}}&{{$params}}{{end}}"{{end}}>
				{{svg "octicon-chevron-left" 16}}
			</a>
			{{range .Pages}}
				{{if eq .Num -1}}
					<span class="feeds-pg-item feeds-pg-ellipsis">…</span>
				{{else}}
					<a class="feeds-pg-item{{if .IsCurrent}} feeds-pg-active{{end}}"
						{{if not .IsCurrent}}href="{{AppSubUrl}}/feeds?page={{.Num}}{{if $params}}&{{$params}}{{end}}"{{end}}>{{.Num}}</a>
				{{end}}
			{{end}}
			<a class="feeds-pg-item feeds-pg-nav{{if not .HasNext}} feeds-pg-disabled{{end}}"
				{{if .HasNext}}href="{{AppSubUrl}}/feeds?page={{.Next}}{{if $params}}&{{$params}}{{end}}"{{end}}>
				{{svg "octicon-chevron-right" 16}}
			</a>
		</nav>
		{{end}}
		{{end}}
	</div>
</div>
{{template "base/footer" .}}
