# PostgreSQL password (generate a strong random password)
POSTGRES_PASSWORD=your-secure-postgres-password-here

# Forkana domain (hostname only — no port, no scheme)
FORKANA_DOMAIN=dev.forkana.example

# Secret key for session encryption (generate with: openssl rand -hex 32)
FORKANA_SECRET_KEY=your-64-character-hex-secret-key-here

# Internal token for API communication between Gitea processes
# (generate with: gitea generate secret INTERNAL_TOKEN)
FORKANA_INTERNAL_TOKEN=

# OAuth2 JWT secret for token signing
# (generate with: gitea generate secret JWT_SECRET)
FORKANA_JWT_SECRET=
